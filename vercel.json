{
  "version": 2,
  "builds": [
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/config.js", "dest": "/public/config.js" },
    { "src": "/(.+\\.(?:css|js|png|jpg|jpeg|gif|svg|ico|webp|woff2?))", "dest": "/public/$1" },
    { "src": "/(.*)", "dest": "/public/index.html" }
  ]
}
